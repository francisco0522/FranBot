# ============================================================
# Variables de entorno — copia este archivo a .env.local
# ============================================================

# API Key de Anthropic (requerida)
# Obtén la tuya en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Puerto del servidor Express (opcional, default: 3001)
PORT=3001

# URL del frontend para CORS en producción (solo para Express/Railway)
# FRONTEND_URL=https://tu-portfolio.vercel.app
