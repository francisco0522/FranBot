# ============================================================
# Variables de entorno — copia este archivo a .env.local
# y reemplaza los valores de ejemplo por los reales.
# ¡NUNCA commitees claves reales! .env.local está en .gitignore
# ============================================================

# API Key de Anthropic (REQUERIDA para el chatbot)
# Obtén la tuya en: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Puerto del servidor Express (opcional, default: 3001)
PORT=3001

# URL del frontend para CORS en producción (solo Express/Railway)
# FRONTEND_URL=https://tu-dominio.com

# Token de GitHub (opcional) — sube el rate limit del fetch de repos
# en /api/chat de 60 a 5000 req/h. Genera uno en:
# https://github.com/settings/tokens (solo scope public_repo o sin scope)
# GITHUB_TOKEN=your_github_token_here

# ── Formulario de contacto (Resend) ─────────────────────────
# API Key de Resend para enviar correos desde la sección Contacto.
# Obtén la tuya en: https://resend.com/api-keys
# RESEND_API_KEY=your_resend_api_key_here

# Remitente verificado en Resend (ej: "Portafolio <contacto@tu-dominio.com>")
# CONTACT_FROM_EMAIL=onboarding@resend.dev
